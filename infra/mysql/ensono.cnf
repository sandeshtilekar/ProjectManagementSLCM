# ============================================================
#  Ensono DataGrid — MySQL 8.0 Optimised Config
#  File: /etc/mysql/mysql.conf.d/ensono.cnf
#  Tuned for: 8 GB RAM VPS, ~50-200 concurrent users
#  Built by Sandesh Tilekar — Ensono India Operations
# ============================================================

[mysqld]

# ── Network / Security ──────────────────────────────────────
bind-address                    = 127.0.0.1  # localhost only — NEVER expose MySQL externally
port                            = 3306
mysqlx                          = 0           # disable X plugin (not needed)
skip-name-resolve               = 1           # skip DNS lookups — faster connections
max_connections                 = 300
max_connect_errors              = 10000
wait_timeout                    = 600
interactive_timeout             = 600

# ── Character Set ────────────────────────────────────────────
character-set-server            = utf8mb4
collation-server                = utf8mb4_unicode_ci
init_connect                    = 'SET NAMES utf8mb4'

# ── InnoDB Storage Engine ────────────────────────────────────
# innodb_buffer_pool_size: aim for 50-70% of available RAM
# On an 8 GB VPS, 4-5 GB is good
innodb_buffer_pool_size         = 4G
innodb_buffer_pool_instances    = 4           # 1 per GB of buffer pool
innodb_log_file_size            = 512M        # larger = fewer checkpoints = faster writes
innodb_log_buffer_size          = 64M
innodb_flush_log_at_trx_commit  = 1           # ACID compliant (use 2 for slightly faster, less safe)
innodb_flush_method             = O_DIRECT    # bypass OS cache for InnoDB files
innodb_file_per_table           = 1           # each table gets its own .ibd file
innodb_stats_on_metadata        = 0
innodb_read_io_threads          = 8
innodb_write_io_threads         = 8
innodb_io_capacity              = 2000        # IOPS capacity of your SSD
innodb_io_capacity_max          = 4000

# ── Query Cache (disabled in MySQL 8) ───────────────────────
# MySQL 8.0 removed query cache — use ProxySQL or app-level cache if needed

# ── Thread / Connection Pool ────────────────────────────────
thread_handling                 = pool-of-threads
thread_pool_size                = 8           # match number of CPU cores
thread_pool_max_threads         = 300
thread_cache_size               = 100
table_open_cache                = 4000
table_definition_cache          = 2000
open_files_limit                = 65535

# ── Temp Tables ─────────────────────────────────────────────
tmp_table_size                  = 128M
max_heap_table_size             = 128M

# ── Sort & Join Buffers ──────────────────────────────────────
sort_buffer_size                = 4M
join_buffer_size                = 4M
read_buffer_size                = 2M
read_rnd_buffer_size            = 4M

# ── Binary Logging (for replication & point-in-time recovery)
log_bin                         = /var/log/mysql/mysql-bin.log
log_bin_index                   = /var/log/mysql/mysql-bin.log.index
binlog_format                   = ROW
binlog_row_image                = MINIMAL     # only log changed columns
expire_logs_days                = 7           # auto-purge after 7 days
max_binlog_size                 = 256M
sync_binlog                     = 1           # flush binlog on every commit

# ── Slow Query Log ───────────────────────────────────────────
slow_query_log                  = 1
slow_query_log_file             = /var/log/mysql/mysql-slow.log
long_query_time                 = 1           # log queries > 1 second
log_queries_not_using_indexes   = 0           # set to 1 temporarily when profiling

# ── Error Log ────────────────────────────────────────────────
log_error                       = /var/log/mysql/error.log
log_error_verbosity             = 2

# ── Performance Schema ───────────────────────────────────────
performance_schema              = ON
performance_schema_max_table_instances = 500

# ── Replication (leave commented unless setting up replica) ──
# server-id                     = 1
# read_only                     = 0

[mysql]
default-character-set           = utf8mb4

[client]
default-character-set           = utf8mb4
